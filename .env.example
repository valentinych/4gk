DATABASE_URL="postgresql://postgres:postgres@localhost:5433/4gk?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Drive API (Music SI)
GOOGLE_API_KEY=""

# Umami analytics — ID from https://analytics.4gk.pl ; for Docker, set before `docker compose build`
UMAMI_WEBSITE_ID=""
UMAMI_HOST="https://analytics.4gk.pl"

# rating.chgk.info — полный заголовок Authorization для GET /tournaments/{id}/results с полем mask (повопросные результаты).
# JWT можно разово получить локально: python3 scripts/rating-chgk-token.py
# RATING_CHGK_AUTHORIZATION="Bearer …"
