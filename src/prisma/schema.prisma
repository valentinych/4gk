generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  chgkId        Int?      @unique
  role          Role      @default(PLAYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  rosters        TeamRoster[]
  eventTeams     EventTeam[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  category    String    @default("news")
  content     String
  excerpt     String?
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DataCache {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id               String   @id @default(cuid())
  title            String
  type             String   @default("tournament")
  startDate        DateTime
  endDate          DateTime?
  startTime        String?
  endTime          String?
  city             String
  venue            String?
  venueMapUrl      String?
  description      String?
  registrationLink String?
  mediaLink        String?
  mediaLinkLabel   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rosters    TeamRoster[]
  eventTeams EventTeam[]
}

model EventTeam {
  id          String   @id @default(cuid())
  eventId     String
  teamChgkId  Int
  teamName    String
  displayName  String?
  playersCount Int?
  addedBy      String
  selfJoined   Boolean  @default(false)
  addedAt     DateTime @default(now())
  withdrawnAt DateTime?
  withdrawnBy String?

  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  addedByUser User          @relation(fields: [addedBy], references: [id])

  @@unique([eventId, teamChgkId])
}

model TeamRoster {
  id          String         @id @default(cuid())
  eventId     String
  userId      String
  teamName    String
  teamChgkId  Int?
  city        String?
  players     RosterPlayer[]
  submittedAt DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model RosterPlayer {
  id         String     @id @default(cuid())
  rosterId   String
  chgkId     Int?
  lastName   String
  firstName  String
  patronymic String?
  isCaptain  Boolean    @default(false)
  isBase     Boolean    @default(false)
  sortOrder  Int        @default(0)

  roster TeamRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
}

model CalendarTemplate {
  id               String   @id @default(cuid())
  name             String
  title            String?
  type             String?
  city             String?
  venue            String?
  venueMapUrl      String?
  description      String?
  registrationLink String?
  mediaLink        String?
  mediaLinkLabel   String?
  startTime        String?
  endTime          String?
  createdAt        DateTime @default(now())
}

enum Role {
  PLAYER
  MODERATOR
  ORGANIZER
  ADMIN
}
